# QAPi – Environment Variable Template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── API Server ────────────────────────────────────────────────────────────────

# Port the Express API server listens on (default: 3000)
PORT=3000

# ── Blob Storage ──────────────────────────────────────────────────────────────

# Base URL for blob-hosted modules (used by the virtual resolver).
# Required only when serving modules of type "blob".
# Example: https://blobs.qapi-omega.vercel.app
QAPI_BLOB_BASE_URL=

# ── Deployment ────────────────────────────────────────────────────────────────

# Public base URL of the deployed API (used for CORS and SDK default baseUrl)
# Example: https://qapi-omega.vercel.app
API_BASE_URL=https://qapi-omega.vercel.app

# ── Node Environment ──────────────────────────────────────────────────────────

# Set to "production" for production deployments
NODE_ENV=development
