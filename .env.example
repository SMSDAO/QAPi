# QAPi – Environment Variable Template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── API Server ────────────────────────────────────────────────────────────────

# Port the Express API server listens on (default: 3000)
PORT=3000

# ── API Key Security ──────────────────────────────────────────────────────────

# HMAC secret used to sign and verify API keys.
# REQUIRED in production — set a long, random string (e.g. `openssl rand -hex 32`).
# If unset in production (VERCEL_ENV=production), the server will refuse to start.
QAPI_KEY_SECRET=

# ── Blob Storage ──────────────────────────────────────────────────────────────

# Base URL for blob-hosted modules (used by the virtual resolver).
# Required only when serving modules of type "blob".
# Example: https://blobs.qapi-omega.vercel.app
QAPI_BLOB_BASE_URL=

# ── Deployment ────────────────────────────────────────────────────────────────

# Public base URL of the deployed API (used for CORS and SDK default baseUrl)
# Example: https://qapi-omega.vercel.app
API_BASE_URL=https://qapi-omega.vercel.app

# ── Node Environment ──────────────────────────────────────────────────────────

# Set to "production" for production deployments
NODE_ENV=development

# ── Claude AI (optional – required only for claudeTimeline feature) ───────────

# Anthropic API key for Claude-powered timeline analysis (Pro+ tiers).
# Obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Redis (optional – enables durable rate-limiting and BullMQ build queue) ───

# Redis connection URL. When unset, in-process fallbacks are used automatically.
# Example: redis://localhost:6379  or  rediss://user:password@host:6380
REDIS_URL=

# ── S3 Artifact Storage (optional – for parallel build engine artifact uploads) ─

# S3 bucket name for storing compiled SDK artifacts.
S3_BUCKET=
# AWS region for the S3 bucket (e.g. us-east-1).
S3_REGION=
