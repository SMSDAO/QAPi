{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "qapi-brain",
  "builds": [
    {
      "src": "apps/core/api/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "dashboard/**/*.{html,js}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/resolve",  "dest": "/apps/core/api/resolve.ts" },
    { "src": "/auth/signup",  "dest": "/apps/core/api/auth-signup.ts" },
    { "src": "/auth/me",      "dest": "/apps/core/api/auth-me.ts" },
    { "src": "/metrics",      "dest": "/apps/core/api/metrics.ts" },
    { "src": "/v1/modules",   "dest": "/apps/core/api/v1-modules.ts" },
    { "src": "/",             "dest": "/dashboard/index.html" },
    { "src": "/(.*)",         "dest": "/dashboard/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",     "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|html)$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
